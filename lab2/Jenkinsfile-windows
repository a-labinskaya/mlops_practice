pipeline {
    agent any

    environment {
        PYTHON = '.venv\\Scripts\\python.exe'
    }

    stages {
        stage('Prepare environment') {
            steps {
                dir('lab2') {
                    bat '''
                        python -m venv .venv
                        .venv\\Scripts\\python.exe -m pip install -r requirements.txt
                    '''
                }
            }
        }

        stage('Data Creation') {
            steps {
                dir('lab2') {
                    bat "%PYTHON% data_creation.py"
                }
            }
        }

        stage('Data Preprocessing') {
            steps {
                dir('lab2') {
                    bat "%PYTHON% data_preprocessing.py"
                }
            }
        }

        stage('Model Preparation') {
            steps {
                dir('lab2') {
                    bat "%PYTHON% model_preparation.py"
                }
            }
        }

        stage('Model Testing') {
            steps {
                dir('lab2') {
                    bat "%PYTHON% model_testing.py"
                }
            }
        }
    }

    post {
        success {
            echo 'Pipeline выполнен успешно!'
        }
        failure {
            echo 'Произошла ошибка при выполнении Pipeline'
        }
    }
}