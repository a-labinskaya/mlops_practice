pipeline {
    agent any

    environment {
        PYTHON = '.venv/bin/python'
    }

    stages {
        stage('Prepare environment') {
            steps {
                dir('lab2') {
                    sh '''
                        python3 -m venv .venv
                        .venv/bin/python -m pip install -r requirements.txt
                    '''
                }
            }
        }

        stage('Data Creation') {
            steps {
                dir('lab2') {
                    sh "${PYTHON} data_creation.py"
                }
            }
        }

        stage('Model Preprocessing') {
            steps {
                dir('lab2') {
                    sh "${PYTHON} data_preprocessing.py"
                }
            }
        }

        stage('Model Preparation') {
            steps {
                dir('lab2') {
                    sh "${PYTHON} model_preparation.py"
                }
            }
        }

        stage('Model Testing') {
            steps {
                dir('lab2') {
                    sh "${PYTHON} model_testing.py"
                }
            }
        }
    }

    post {
        success {
            echo 'Pipeline выполнен успешно!'
        }
        failure {
            echo 'Произошла ошибка при выполнении Pipeline'
        }
    }
}